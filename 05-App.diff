+function AdminCustomFrameworksPanel() {
+  const blankControl = () => ({ _key: Math.random().toString(36).slice(2), title: "", description: "", category: "" });
+  const blankForm = () => ({ id: null, name: "", description: "", controls: [blankControl()] });
+
+  const [list, setList] = useState([]);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState(null);
+  const [notice, setNotice] = useState(null);
+  const [busy, setBusy] = useState(false);
+  const [editing, setEditing] = useState(false);
+  const [form, setForm] = useState(blankForm());
+  const [confirmDelete, setConfirmDelete] = useState(null);
+
+  async function load() {
+    setLoading(true); setError(null);
+    try {
+      const res = await authFetch(`${API_BASE}/api/frameworks`);
+      const d = await res.json();
+      if (!res.ok) throw new Error(d.error || "Could not load frameworks.");
+      setList(d.frameworks || []);
+    } catch (e) { setError(e.message); }
+    finally { setLoading(false); }
+  }
+  useEffect(() => { load(); }, []);
+
+  function startCreate() { setForm(blankForm()); setEditing(true); setNotice(null); }
+
+  async function startEdit(id) {
+    setError(null);
+    try {
+      const res = await authFetch(`${API_BASE}/api/frameworks/${id}`);
+      const d = await res.json();
+      if (!res.ok) throw new Error(d.error || "Could not load that framework.");
+      const fw = d.framework;
+      setForm({
+        id: fw.id, name: fw.name, description: fw.description || "",
+        controls: (fw.controls?.length ? fw.controls : [blankControl()])
+          .map(c => ({ _key: c.id || Math.random().toString(36).slice(2), id: c.id, title: c.title, description: c.description || "", category: c.category || "" })),
+      });
+      setEditing(true);
+    } catch (e) { setError(e.message); }
+  }
+
+  function updateControl(key, field, value) {
+    setForm(f => ({ ...f, controls: f.controls.map(c => c._key === key ? { ...c, [field]: value } : c) }));
+  }
+  function addControl() { setForm(f => ({ ...f, controls: [...f.controls, blankControl()] })); }
+  function removeControl(key) { setForm(f => ({ ...f, controls: f.controls.filter(c => c._key !== key) })); }
+
+  async function save() {
+    if (!form.name.trim()) { setError("Framework name is required."); return; }
+    setBusy(true); setError(null);
+    try {
+      const controls = form.controls
+        .filter(c => c.title.trim())
+        .map(c => ({ id: c.id, title: c.title.trim(), description: c.description.trim(), category: c.category.trim() }));
+      const res = await authFetch(`${API_BASE}/api/frameworks`, {
+        method: "POST", headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ id: form.id, name: form.name.trim(), description: form.description.trim(), controls }),
+      });
+      const d = await res.json();
+      if (!res.ok) throw new Error(d.error || "Could not save framework.");
+      setNotice(`Saved "${d.framework.name}" with ${d.framework.controls.length} control(s).`);
+      setEditing(false);
+      await load();
+    } catch (e) { setError(e.message); }
+    finally { setBusy(false); }
+  }
+
+  async function doDelete(id) {
+    setBusy(true); setError(null);
+    try {
+      const res = await authFetch(`${API_BASE}/api/frameworks/${id}`, { method: "DELETE" });
+      const d = await res.json();
+      if (!res.ok || !d.ok) throw new Error(d.error || "Could not delete framework.");
+      setConfirmDelete(null);
+      setNotice("Framework deleted.");
+      await load();
+    } catch (e) { setError(e.message); }
+    finally { setBusy(false); }
+  }
+
+  if (loading) return <Spinner/>;
+
+  return (
+    <div>
+      <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:14}}>
+        <SectionLabel text="Custom Frameworks"/>
+        {!editing && (
+          <button onClick={startCreate}
+            style={{marginLeft:"auto",padding:"7px 16px",background:`linear-gradient(135deg,${C.accent},${C.accentDm})`,
+              color:C.bg,border:"none",borderRadius:8,fontSize:13,fontWeight:700,cursor:"pointer"}}>
+            + Add Framework
+          </button>
+        )}
+      </div>
+
+      {notice && (
+        <div style={{marginBottom:16,padding:"10px 14px",background:`${C.green}15`,
+          border:`1px solid ${C.green}33`,borderRadius:8,color:C.green,fontSize:13}}>{notice}</div>
+      )}
+      {error && (
+        <div style={{marginBottom:16,padding:"10px 14px",background:`${C.red}15`,
+          border:`1px solid ${C.red}33`,borderRadius:8,color:C.red,fontSize:13}}>{error}</div>
+      )}
+
+      <div style={{marginBottom:16,padding:"11px 14px",background:C.surface,
+        border:`1px solid ${C.border}`,borderRadius:8,fontSize:12,color:C.textSec,lineHeight:1.6}}>
+        Frameworks defined here appear to clients and analysts under Compliance → Custom frameworks,
+        with per-control status tracked separately from the built-in engine (agent-measured where
+        possible, otherwise self-reported). A framework with no controls yet shows clients an honest
+        "nothing to assess" state rather than a fabricated score.
+      </div>
+
+      {editing ? (
+        <Card style={{marginBottom:14}}>
+          <div style={{display:"grid",gap:12,marginBottom:14}}>
+            <div>
+              <label style={{display:"block",fontSize:11.5,color:C.textSec,marginBottom:5}}>Framework name *</label>
+              <input value={form.name} onChange={e=>setForm(f=>({...f,name:e.target.value}))}
+                placeholder="e.g. Acme Vendor Security Addendum"
+                style={{width:"100%",padding:"9px 11px",background:C.surface,border:`1px solid ${C.border}`,
+                  borderRadius:7,color:C.text,fontSize:13,fontFamily:"Inter,system-ui,sans-serif"}}/>
+            </div>
+            <div>
+              <label style={{display:"block",fontSize:11.5,color:C.textSec,marginBottom:5}}>Description</label>
+              <textarea value={form.description} onChange={e=>setForm(f=>({...f,description:e.target.value}))}
+                rows={2} placeholder="What this framework covers and why it applies to this client."
+                style={{width:"100%",padding:"9px 11px",background:C.surface,border:`1px solid ${C.border}`,
+                  borderRadius:7,color:C.text,fontSize:13,fontFamily:"Inter,system-ui,sans-serif",resize:"vertical"}}/>
+            </div>
+          </div>
+
+          <div style={{color:C.textSec,fontSize:12,fontWeight:700,marginBottom:8}}>
+            Controls ({form.controls.filter(c=>c.title.trim()).length})
+          </div>
+          <div style={{display:"grid",gap:10,marginBottom:12}}>
+            {form.controls.map((c,i) => (
+              <div key={c._key} style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:8,padding:"10px 12px"}}>
+                <div style={{display:"flex",gap:8,marginBottom:8,alignItems:"center"}}>
+                  <span style={{color:C.textMut,fontSize:11,fontFamily:"monospace",minWidth:18}}>{i+1}.</span>
+                  <input value={c.title} onChange={e=>updateControl(c._key,"title",e.target.value)}
+                    placeholder="Control title (required)"
+                    style={{flex:1,padding:"7px 10px",background:C.card,border:`1px solid ${C.border}`,
+                      borderRadius:6,color:C.text,fontSize:12.5,fontFamily:"Inter,system-ui,sans-serif"}}/>
+                  <input value={c.category} onChange={e=>updateControl(c._key,"category",e.target.value)}
+                    placeholder="Category (optional)"
+                    style={{width:160,padding:"7px 10px",background:C.card,border:`1px solid ${C.border}`,
+                      borderRadius:6,color:C.text,fontSize:12.5,fontFamily:"Inter,system-ui,sans-serif"}}/>
+                  <button onClick={()=>removeControl(c._key)}
+                    style={{padding:"7px 10px",background:"none",border:`1px solid ${C.border}`,
+                      borderRadius:6,color:C.textMut,fontSize:11,cursor:"pointer"}}>Remove</button>
+                </div>
+                <input value={c.description} onChange={e=>updateControl(c._key,"description",e.target.value)}
+                  placeholder="What this control requires (optional, shown to the client)"
+                  style={{width:"100%",padding:"7px 10px",background:C.card,border:`1px solid ${C.border}`,
+                    borderRadius:6,color:C.textSec,fontSize:12,fontFamily:"Inter,system-ui,sans-serif"}}/>
+              </div>
+            ))}
+          </div>
+          <button onClick={addControl}
+            style={{padding:"7px 14px",background:"none",border:`1px dashed ${C.border}`,
+              borderRadius:7,color:C.textSec,fontSize:12,cursor:"pointer",marginBottom:16}}>
+            + Add control
+          </button>
+
+          <div style={{display:"flex",gap:10}}>
+            <button onClick={()=>{setEditing(false);setError(null);}}
+              style={{padding:"9px 16px",background:"none",border:`1px solid ${C.border}`,
+                borderRadius:8,color:C.textSec,fontSize:13,cursor:"pointer"}}>
+              Cancel
+            </button>
+            <button onClick={save} disabled={busy}
+              style={{padding:"9px 18px",background:`linear-gradient(135deg,${C.accent},${C.accentDm})`,
+                color:C.bg,border:"none",borderRadius:8,fontSize:13,fontWeight:700,
+                cursor:busy?"default":"pointer",marginLeft:"auto"}}>
+              {busy ? "Saving…" : form.id ? "Save changes" : "Create framework"}
+            </button>
+          </div>
+        </Card>
+      ) : list.length === 0 ? (
+        <Card><div style={{color:C.textSec,fontSize:13,padding:"8px 0"}}>
+          No custom frameworks yet. Add one for a client whose obligations go beyond the standard catalogue.
+        </div></Card>
+      ) : list.map(f => (
+        <Card key={f.id} style={{marginBottom:10}}>
+          <div style={{display:"flex",alignItems:"flex-start",gap:12,flexWrap:"wrap"}}>
+            <div style={{flex:"1 1 260px",minWidth:0}}>
+              <div style={{display:"flex",alignItems:"center",gap:9,marginBottom:5,flexWrap:"wrap"}}>
+                <span style={{fontSize:14,fontWeight:700,color:C.text}}>{f.name}</span>
+                <Badge label={`${f.controlCount} CONTROL${f.controlCount===1?"":"S"}`} color={f.controlCount>0?C.purple:C.textMut}/>
+              </div>
+              {f.description && <div style={{fontSize:12,color:C.textSec,lineHeight:1.5}}>{f.description}</div>}
+            </div>
+            <div style={{display:"flex",gap:7,flexWrap:"wrap"}}>
+              <button onClick={()=>startEdit(f.id)}
+                style={{padding:"7px 12px",background:C.surface,border:`1px solid ${C.border}`,
+                  borderRadius:6,color:C.textSec,fontSize:11.5,cursor:"pointer"}}>
+                Edit
+              </button>
+              {confirmDelete === f.id ? (
+                <button onClick={()=>doDelete(f.id)} disabled={busy}
+                  style={{padding:"7px 12px",background:`${C.red}18`,border:`1px solid ${C.red}55`,
+                    borderRadius:6,color:C.red,fontSize:11.5,fontWeight:600,cursor:busy?"default":"pointer"}}>
+                  {busy ? "Deleting…" : "Confirm delete"}
+                </button>
+              ) : (
+                <button onClick={()=>setConfirmDelete(f.id)}
+                  style={{padding:"7px 12px",background:"none",border:`1px solid ${C.border}`,
+                    borderRadius:6,color:C.textMut,fontSize:11.5,cursor:"pointer"}}>
+                  Delete
+                </button>
+              )}
+            </div>
+          </div>
+        </Card>
+      ))}
+    </div>
+  );
+}
