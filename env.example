# ShieldAI environment variables
# Copy to .env for local development. NEVER commit .env — only this file.
# In production these are set in Railway → Variables, not in any file.

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
JWT_SECRET=

# ── AI providers (optional — fallback chain) ──────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=

# ── Threat intelligence ───────────────────────────────────────
# Required for breach monitoring. Without it: "Not active" (never a fake all-clear).
HIBP_API_KEY=
HIBP_USER_AGENT=ShieldAI-vCISO
# Optional. Without it, CVE refreshes take ~78s instead of ~8s. Free key:
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Demo sandbox ──────────────────────────────────────────────
# MUST differ from JWT_SECRET, or demo tokens could be verified as production
# tokens and the sandbox isolation would collapse.
DEMO_JWT_SECRET=
SEED_DEMO_ON_BOOT=false
SEED_DEMO_FORCE=false

# ── Billing (optional — routes return 503 without these) ───────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Config (not secrets) ──────────────────────────────────────
ADMIN_EMAIL=
ANALYST_EMAIL=
APP_URL=
PORT=3001
# Must point at the mounted volume in production (Railway: /data)
DB_DIR=
